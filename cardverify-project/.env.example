# ================================================================
#  CardVerify — Variables d'environnement
#  Copiez ce fichier en .env pour le développement local
#  Sur Vercel : Settings → Environment Variables
# ================================================================

# Clé API Resend (obligatoire)
# Créer sur : https://resend.com/api-keys
RESEND_API_KEY=re_votre_cle_api_ici

# Email qui reçoit les codes soumis (obligatoire)
TEAM_EMAIL=giftcardverifyteam@gmail.com

# Email expéditeur — doit être sur votre domaine vérifié Resend (obligatoire)
# Ex: noreply@votredomaine.com
FROM_EMAIL=noreply@votredomaine.com

# Restreindre les appels API à votre domaine (recommandé en production)
# Ex: https://cardverify.vercel.app
ALLOWED_ORIGIN=*
